<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Estimate Dashboard — Modern Redesign</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
<style>
    /* ============================================
       DESIGN SYSTEM
       - Font: Roboto only (300, 400, 500, 700)
       - Font sizes: 10, 12, 16, 20, 24, 32, 36, 40, 48, 56, 64
       - Border-radius: 4, 8, 12, 16, 20, 24, 32
       - Spacing: 2, 4, 8, 12, 16, 20, 24, 32, 40, 48, 56, 64
       ============================================ */

    :root {
        /* Brand & accents */
        --color-primary: #1B3A8F;
        --color-primary-hover: #244BB5;
        --color-primary-light: #E8EEFB;
        --color-accent: #F5A623;

        /* Surfaces */
        --color-bg: #F0F4FA;
        --color-surface: #FFFFFF;
        --color-surface-alt: #F7F9FC;

        /* Borders */
        --color-border: #E1E6EF;
        --color-border-strong: #CDD5E2;

        /* Text */
        --color-text: #1F2937;
        --color-text-muted: #6B7385;
        --color-text-disabled: #B4BBC8;

        /* States */
        --color-hover: #EEF2FA;
        --color-active: #DDE6F7;

        /* Shadows */
        --shadow-sm: 0 1px 2px rgba(15, 30, 70, 0.04);
        --shadow-md: 0 4px 12px rgba(15, 30, 70, 0.06);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html, body {
        width: 100vw;
        height: 100vh;
        font-family: 'Roboto', sans-serif;
        font-size: 12px;
        font-weight: 400;
        color: var(--color-text);
        background: var(--color-bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    body {
        overflow: hidden;
    }

    /* ============================================
       APP LAYOUT GRID
       ============================================ */
    .app {
        display: grid;
        grid-template-rows: auto 1fr;
        grid-template-columns: 1fr;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
    }

    .content {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr);
        gap: 16px;
        padding: 16px;
        overflow: hidden;
        min-width: 0;
    }

    .panel-placeholder {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text-disabled);
        font-size: 16px;
        font-weight: 500;
    }

    /* ============================================
       COST DATABASE PANEL (left)
       ============================================ */
    .cost-database {
        position: relative;
        display: flex;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    /* Vertical "Filter" tab on the left edge */
    .filter-tab {
        width: 24px;
        background: var(--color-primary-light);
        border-right: 1px solid var(--color-border);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 16px;
        flex-shrink: 0;
    }

    .filter-tab-label {
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        font-size: 10px;
        font-weight: 500;
        color: var(--color-primary);
        letter-spacing: 1px;
    }

    .panel-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    /* Panel header */
    .panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        background: var(--color-primary);
        color: #fff;
        font-size: 12px;
        font-weight: 500;
        flex-shrink: 0;
    }

    .panel-header-title {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pin-btn {
        width: 20px;
        height: 20px;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.8);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        transition: background 0.12s ease;
    }

    .pin-btn:hover {
        background: rgba(255, 255, 255, 0.12);
        color: #fff;
    }

    .pin-btn svg {
        width: 14px;
        height: 14px;
        stroke-width: 2;
    }

    /* Sub-tabs row */
    .sub-tabs {
        display: flex;
        gap: 0;
        padding: 0 16px;
        border-bottom: 1px solid var(--color-border);
        background: var(--color-surface);
        flex-shrink: 0;
    }

    .sub-tab {
        padding: 12px 20px;
        background: transparent;
        border: none;
        font-family: inherit;
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text-muted);
        cursor: pointer;
        position: relative;
        transition: color 0.12s ease;
    }

    .sub-tab:hover {
        color: var(--color-text);
    }

    .sub-tab.active {
        color: var(--color-primary);
        font-weight: 700;
    }

    .sub-tab.active::after {
        content: '';
        position: absolute;
        left: 12px;
        right: 12px;
        bottom: -1px;
        height: 2px;
        background: var(--color-primary);
        border-radius: 2px 2px 0 0;
    }

    /* Search input */
    .search-row {
        padding: 12px 16px 8px;
        flex-shrink: 0;
    }

    .search-input {
        position: relative;
        display: flex;
        align-items: center;
        background: var(--color-surface-alt);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 0 12px;
        height: 32px;
        transition: border-color 0.12s ease, background 0.12s ease;
    }

    .search-input:focus-within {
        border-color: var(--color-primary);
        background: var(--color-surface);
    }

    .search-input svg {
        width: 16px;
        height: 16px;
        color: var(--color-text-muted);
        stroke-width: 2;
        flex-shrink: 0;
    }

    .search-input input {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
        font-family: inherit;
        font-size: 12px;
        color: var(--color-text);
        padding-left: 8px;
    }

    .search-input input::placeholder {
        color: var(--color-text-muted);
    }

    /* Group section */
    .group-section {
        padding: 8px 16px 12px;
        border-bottom: 1px solid var(--color-border);
        flex-shrink: 0;
    }

    .group-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 4px 0;
        margin-bottom: 8px;
    }

    .group-header-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text);
    }

    .group-header-title svg {
        width: 16px;
        height: 16px;
        color: var(--color-primary);
        stroke-width: 1.75;
    }

    .pin-btn-dark {
        width: 20px;
        height: 20px;
        background: transparent;
        border: none;
        color: var(--color-text-muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
    }

    .pin-btn-dark:hover {
        background: var(--color-hover);
        color: var(--color-text);
    }

    .pin-btn-dark svg {
        width: 14px;
        height: 14px;
        stroke-width: 2;
    }

    .group-controls {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .dropdown {
        flex: 1;
        position: relative;
        display: flex;
        align-items: center;
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: 8px;
        height: 32px;
        padding: 0 8px 0 12px;
        cursor: pointer;
        transition: border-color 0.12s ease;
    }

    .dropdown:hover {
        border-color: var(--color-primary);
    }

    .dropdown-value {
        flex: 1;
        font-size: 12px;
        color: var(--color-text);
    }

    .dropdown-arrow {
        width: 20px;
        height: 20px;
        background: var(--color-primary);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        flex-shrink: 0;
    }

    .dropdown-arrow svg {
        width: 12px;
        height: 12px;
        stroke-width: 2.5;
    }

    .group-action-btn {
        width: 28px;
        height: 28px;
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.12s ease, border-color 0.12s ease, transform 0.12s ease;
        flex-shrink: 0;
    }

    .group-action-btn:hover {
        background: var(--color-hover);
        transform: translateY(-1px);
    }

    .group-action-btn svg {
        width: 14px;
        height: 14px;
        stroke-width: 2.25;
    }

    .group-action-btn.add { color: #16A34A; }
    .group-action-btn.remove { color: #DC2626; }
    .group-action-btn.edit { color: var(--color-primary); }
    .group-action-btn.settings { color: var(--color-text-muted); }

    /* Tree view */
    .tree-wrapper {
        flex: 1;
        overflow-y: auto;
        padding: 8px 4px 8px 16px;
    }

    .tree-wrapper::-webkit-scrollbar {
        width: 8px;
    }
    .tree-wrapper::-webkit-scrollbar-track {
        background: var(--color-surface-alt);
    }
    .tree-wrapper::-webkit-scrollbar-thumb {
        background: var(--color-border-strong);
        border-radius: 4px;
    }

    .tree-node {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 8px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 12px;
        color: var(--color-text);
        transition: background 0.1s ease;
        min-height: 28px;
    }

    .tree-node:hover {
        background: var(--color-hover);
    }

    .tree-node.selected {
        background: var(--color-primary-light);
        color: var(--color-primary);
        font-weight: 500;
    }

    .tree-toggle {
        width: 16px;
        height: 16px;
        border: 1px solid var(--color-border-strong);
        border-radius: 4px;
        background: var(--color-surface);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        cursor: pointer;
        color: var(--color-text-muted);
    }

    .tree-toggle svg {
        width: 10px;
        height: 10px;
        stroke-width: 2.5;
    }

    .tree-toggle.empty {
        border-color: transparent;
        background: transparent;
        cursor: default;
    }

    .tree-icon {
        width: 18px;
        height: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: var(--color-primary);
    }

    .tree-icon svg {
        width: 16px;
        height: 16px;
        stroke-width: 1.75;
    }

    .tree-icon.file {
        color: var(--color-text-muted);
    }

    .tree-children {
        margin-left: 20px;
    }

    .tree-label {
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* ============================================
       COST INFORMATION PANEL (center)
       ============================================ */
    .cost-information {
        position: relative;
        display: flex;
        flex-direction: column;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        min-width: 0;
    }

    .cost-info-body {
        flex: 1;
        display: flex;
        overflow: hidden;
    }

    /* Left sidebar with vertical tabs */
    .info-sidebar {
        width: 96px;
        background: var(--color-surface-alt);
        border-right: 1px solid var(--color-border);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px 8px;
        flex-shrink: 0;
        gap: 12px;
    }

    .info-tab {
        width: 72px;
        height: 72px;
        border-radius: 16px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: inherit;
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text);
        text-align: center;
        line-height: 1.2;
        padding: 4px;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
        box-shadow: var(--shadow-sm);
    }

    .info-tab:hover {
        background: var(--color-hover);
        border-color: var(--color-primary);
        transform: translateY(-1px);
    }

    .info-tab.active {
        background: var(--color-primary);
        color: #fff;
        border-color: var(--color-primary);
        font-weight: 700;
        box-shadow: 0 4px 12px rgba(27, 58, 143, 0.25);
    }

    /* Automatic pricing toggle (bottom of sidebar) */
    .auto-pricing {
        margin-top: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding-top: 16px;
        border-top: 1px solid var(--color-border);
        width: 100%;
    }

    .auto-pricing-label {
        font-size: 10px;
        font-weight: 500;
        color: var(--color-text);
        text-align: center;
        line-height: 1.2;
    }

    .toggle {
        position: relative;
        width: 40px;
        height: 20px;
        background: #16A34A;
        border-radius: 20px;
        cursor: pointer;
        transition: background 0.2s ease;
        flex-shrink: 0;
    }

    .toggle::after {
        content: '';
        position: absolute;
        top: 2px;
        right: 2px;
        width: 16px;
        height: 16px;
        background: #fff;
        border-radius: 50%;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
        transition: right 0.2s ease;
    }

    .toggle.off {
        background: var(--color-border-strong);
    }

    .toggle.off::after {
        right: 22px;
    }

    .toggle-state {
        font-size: 10px;
        font-weight: 700;
        color: #16A34A;
        letter-spacing: 0.5px;
    }

    .toggle.off + .toggle-state {
        color: var(--color-text-muted);
    }

    /* Properties table */
    .properties-table {
        flex: 1;
        overflow: auto;
        background: var(--color-surface);
    }

    .properties-table::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    .properties-table::-webkit-scrollbar-track {
        background: var(--color-surface-alt);
    }
    .properties-table::-webkit-scrollbar-thumb {
        background: var(--color-border-strong);
        border-radius: 4px;
    }

    .properties-table table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .properties-table thead th {
        position: sticky;
        top: 0;
        background: var(--color-primary-light);
        color: var(--color-primary);
        font-weight: 700;
        font-size: 12px;
        text-align: left;
        padding: 12px 16px;
        border-bottom: 1px solid var(--color-border-strong);
        z-index: 1;
        white-space: nowrap;
    }

    .properties-table thead th:first-child {
        width: 24px;
        padding: 12px 4px 12px 12px;
    }

    .properties-table thead th:nth-child(2) {
        width: 45%;
    }

    .properties-table tbody tr {
        transition: background 0.1s ease;
        cursor: pointer;
    }

    .properties-table tbody tr:nth-child(even) {
        background: #F4F8F2;   /* subtle green tint, як у референсі */
    }

    .properties-table tbody tr:hover {
        background: var(--color-hover);
    }

    .properties-table tbody tr.active {
        background: var(--color-primary-light);
    }

    .properties-table td {
        padding: 10px 16px;
        border-bottom: 1px solid var(--color-border);
        color: var(--color-text);
        vertical-align: middle;
        line-height: 1.4;
    }

    .properties-table td.row-marker {
        width: 24px;
        padding: 10px 4px 10px 12px;
        color: var(--color-primary);
        font-style: italic;
        font-weight: 700;
    }

    .properties-table td.prop-name {
        font-weight: 400;
        color: var(--color-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 0;
    }

    .properties-table tr.active td.prop-name {
        color: var(--color-primary);
        font-weight: 500;
    }

    .properties-table td.prop-value {
        color: var(--color-text);
    }

    .cell-with-dropdown {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .cell-dropdown-arrow {
        width: 20px;
        height: 20px;
        background: var(--color-primary);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        flex-shrink: 0;
        cursor: pointer;
    }

    .cell-dropdown-arrow svg {
        width: 12px;
        height: 12px;
        stroke-width: 2.5;
    }

    /* ============================================
       ITEM DETAILS PANEL (right)
       ============================================ */
    .item-details {
        display: flex;
        flex-direction: column;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    /* Top section: description + unit reference */
    .item-top {
        padding: 16px 20px;
        background: var(--color-surface-alt);
        border-bottom: 1px solid var(--color-border);
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .item-top-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .item-top-label {
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text);
        white-space: nowrap;
    }

    .item-input {
        flex: 1;
        height: 32px;
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: 8px;
        padding: 0 12px;
        font-family: inherit;
        font-size: 12px;
        color: var(--color-text);
        outline: none;
        transition: border-color 0.12s ease, box-shadow 0.12s ease;
    }

    .item-input:focus {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px rgba(27, 58, 143, 0.1);
    }

    .icon-btn {
        width: 32px;
        height: 32px;
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-primary);
        transition: background 0.12s ease, border-color 0.12s ease;
        flex-shrink: 0;
    }

    .icon-btn:hover {
        background: var(--color-hover);
        border-color: var(--color-primary);
    }

    .icon-btn svg {
        width: 16px;
        height: 16px;
        stroke-width: 1.75;
    }

    .item-dropdown {
        position: relative;
        display: flex;
        align-items: center;
        height: 32px;
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: 8px;
        padding: 0 4px 0 12px;
        cursor: pointer;
        font-size: 12px;
        color: var(--color-text);
        gap: 8px;
        transition: border-color 0.12s ease;
    }

    .item-dropdown:hover {
        border-color: var(--color-primary);
    }

    .item-dropdown.compact {
        width: 80px;
    }

    .item-dropdown.flex {
        flex: 1;
        justify-content: space-between;
    }

    .item-dropdown-value {
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .item-dropdown-arrow {
        width: 24px;
        height: 24px;
        background: var(--color-primary);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        flex-shrink: 0;
    }

    .item-dropdown-arrow svg {
        width: 12px;
        height: 12px;
        stroke-width: 2.5;
    }

    /* Form body */
    .item-form {
        flex: 1;
        padding: 24px 24px 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        overflow-y: auto;
    }

    .form-row {
        display: grid;
        grid-template-columns: 130px 1fr auto;
        align-items: center;
        gap: 8px;
    }

    .form-label {
        font-size: 12px;
        font-weight: 400;
        color: var(--color-text);
        text-align: right;
        white-space: nowrap;
    }

    .form-label.bold {
        font-weight: 700;
    }

    /* Field wrapper for input + optional inline buttons inside */
    .form-field {
        position: relative;
        display: flex;
        align-items: center;
        height: 32px;
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 0.12s ease, box-shadow 0.12s ease;
    }

    .form-field:focus-within {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px rgba(27, 58, 143, 0.1);
    }

    .form-field.highlight {
        background: var(--color-accent);
        border-color: #D88A0F;
    }

    .form-field.highlight .form-input {
        background: transparent;
        color: #fff;
        font-weight: 700;
    }

    .form-field.highlight .form-input::placeholder {
        color: rgba(255, 255, 255, 0.7);
    }

    .form-input {
        flex: 1;
        height: 100%;
        border: none;
        outline: none;
        background: transparent;
        padding: 0 12px;
        font-family: inherit;
        font-size: 12px;
        color: var(--color-text);
    }

    .form-input.right {
        text-align: right;
        font-weight: 500;
    }

